NEXT_PUBLIC_APP_NAME="Solar Tank Monitoring System"
NEXT_PUBLIC_APP_ENV="development"

# Cloudflare Turnstile untuk verifikasi keamanan halaman masuk.
# Isi dengan key development/production dari Cloudflare saat auth diaktifkan.
NEXT_PUBLIC_TURNSTILE_SITE_KEY=""
TURNSTILE_SECRET_KEY=""

# Key lokal untuk POST /api/ingest dan simulator device.
# Nilai ini hanya contoh development, bukan secret production.
SOLAR_TANK_LOCAL_DEVICE_KEY="local-development-key"

# Jangan commit database URL asli, API key perangkat production,
# rahasia SMTP, kredensial WiFi, token deployment, atau domain production.

# Variabel berikut belum aktif pada fase saat ini.
# Aktifkan nanti jika database, auth, atau deployment sudah dibuat.
# DATABASE_URL="file:./local-dev.db"
# AUTH_SECRET="ganti-dengan-secret-lokal"
# APP_BASE_URL="http://localhost:3000"
