NEXT_PUBLIC_APP_NAME="FTM - Fuel Tank Management"
NEXT_PUBLIC_APP_ENV="development"
NEXT_PUBLIC_MONITORING_REFRESH_INTERVAL_MS="20000"

# Mode storage:
# - "memory" = default development, data hilang saat server restart
# - "mysql"  = data reading disimpan ke MySQL
SOLAR_TANK_STORAGE_DRIVER="memory"

# Key global lokal untuk fallback development POST /api/ingest.
# Nilai ini hanya contoh development, bukan secret production.
SOLAR_TANK_LOCAL_DEVICE_KEY="local-development-key"

# Fallback global memudahkan latihan awal.
# Untuk pilot/production, set ke "false" dan gunakan hash key per device.
SOLAR_TANK_ALLOW_GLOBAL_DEVICE_KEY_FALLBACK="true"

# Auto provisioning membuat site/tangki/device baru dari payload firmware.
# Default aplikasi adalah nonaktif. Aktifkan hanya saat onboarding device baru.
# Untuk pilot/production, tetap matikan global fallback dan wajib pakai provisioning key khusus.
SOLAR_TANK_AUTO_PROVISION_DEVICES="false"

# Device baru wajib mengirim header X-Provisioning-Key dengan nilai ini saat auto provisioning aktif.
# Device tetap memakai X-Api-Key sebagai key spesifik device yang akan disimpan hash-nya.
SOLAR_TANK_DEVICE_PROVISIONING_KEY=""

# Override key simulator untuk satu device jika diperlukan.
# Jika kosong, simulator memakai key demo sesuai device dummy.
# SOLAR_TANK_DEVICE_KEY="demo-tph-key"

# Aktifkan hanya saat SOLAR_TANK_STORAGE_DRIVER="mysql".
# Jangan isi password asli di .env.example.
# MYSQL_DATABASE_URL="mysql://solar_tank_app:password@127.0.0.1:3306/solar_tank_monitoring"

# Batas koneksi pool MySQL.
# Untuk Vercel/serverless awal, pakai nilai kecil seperti 1 atau 2.
# MYSQL_CONNECTION_LIMIT="2"

# SSL/TLS untuk MySQL cloud.
# Gunakan "required" jika provider database mewajibkan koneksi aman.
# Gunakan "disabled" hanya untuk development lokal atau provider yang memang tidak memakai TLS.
# MYSQL_SSL_MODE="required"

# Isi hanya jika provider memberi CA certificate.
# Jika certificate multi-line, simpan dengan karakter \n.
# MYSQL_SSL_CA="-----BEGIN CERTIFICATE-----\n...\n-----END CERTIFICATE-----"

# Backup MySQL.
# Output default aman untuk lokal: backups/mysql dan sudah di-ignore git.
# Untuk Google Drive, arahkan folder ini ke folder Google Drive Desktop/rclone di server.
# MYSQL_BACKUP_OUTPUT_DIR="backups/mysql"
# MYSQL_BACKUP_RETENTION_DAYS="90"

# Token opsional untuk membuka /api/ready dari monitoring operasional tanpa login browser.
# Production tetap bisa membuka /api/ready lewat session admin.
# Buat token random panjang, jangan pakai nilai pendek atau commit token asli.
# READINESS_CHECK_TOKEN=""

# Auth user dashboard.
# Jangan isi secret asli di .env.example.
# AUTH_SESSION_COOKIE_NAME="solar_tank_session"
# AUTH_SECRET="ganti-dengan-secret-minimal-32-karakter"
# AUTH_REQUIRE_ADMIN_OTP="true"
# AUTH_ENABLE_REGISTER="true"
# AUTH_ALLOW_PASSWORD_RESET="true"
# AUTH_REQUIRE_EMAIL_VERIFICATION_FOR_APPROVAL="true"
# AUTH_COOKIE_SECURE="false"
# AUTH_PASSWORD_RESET_TTL_SECONDS="1800"
# AUTH_EMAIL_VERIFICATION_TTL_SECONDS="86400"
# AUTH_TELEGRAM_BIND_TTL_SECONDS="600"
# AUTH_SESSION_LAST_SEEN_UPDATE_SECONDS="300"
# APP_BASE_URL dipakai untuk link email verifikasi dan reset password.
# Lokal boleh http://localhost:3000; production wajib domain aplikasi asli.
# APP_BASE_URL="http://localhost:3000"
# AUTH_BOOTSTRAP_ADMIN_EMAIL="admin@example.com"
# AUTH_BOOTSTRAP_ADMIN_USERNAME="admin"
# AUTH_BOOTSTRAP_ADMIN_FULL_NAME="Administrator"
# AUTH_BOOTSTRAP_ADMIN_PASSWORD="ganti-dengan-password-kuat"

# SMTP untuk OTP admin.
# SMTP_HOST="smtp.example.com"
# SMTP_PORT="587"
# SMTP_USER="smtp-user"
# SMTP_PASS="smtp-password"
# SMTP_FROM="FTM <noreply@example.com>"
# SMTP_SECURE="false"

# Paket firmware pengajuan perangkat.
# DEVICE_PACKAGE_ENCRYPTION_KEY wajib diisi untuk production.
# Buat key 32 byte base64 dengan: node -e "console.log(require('node:crypto').randomBytes(32).toString('base64url'))"
# DEVICE_PACKAGE_ENCRYPTION_KEY=""
# DEVICE_PACKAGE_DOWNLOAD_TTL_DAYS="7"
# DEVICE_PACKAGE_MAX_DOWNLOADS="3"

# CAPTCHA untuk form publik.
# Provider yang didukung sekarang hanya "disabled" atau "turnstile".
# Nilai lain dianggap salah konfigurasi dan membuat readiness gagal.
# Jika provider "turnstile", isi site key di client dan secret key di server.
# AUTH_CAPTCHA_PROVIDER="disabled"
# NEXT_PUBLIC_AUTH_CAPTCHA_SITE_KEY=""
# AUTH_CAPTCHA_SECRET_KEY=""

# Telegram bot untuk binding akun dan notifikasi keamanan.
# TELEGRAM_BOT_TOKEN=""
# TELEGRAM_WEBHOOK_SECRET=""
# TELEGRAM_BOT_USERNAME="FTMMonitoringBot"
# Opsional: kirim notifikasi admin ke Telegram group forum/topic.
# Jika group/topic belum diisi, sistem fallback ke private chat admin yang sudah bind.
# TELEGRAM_ADMIN_GROUP_CHAT_ID=""
# TELEGRAM_TOPIC_NEW_ACCOUNT_THREAD_ID=""
# TELEGRAM_TOPIC_NEW_DEVICE_THREAD_ID=""
# TELEGRAM_TOPIC_LIVE_CHAT_THREAD_ID=""
# TELEGRAM_TOPIC_SYSTEM_THREAD_ID=""

# Pilot registry dan smoke test.
# Variabel ini dipakai script terminal, bukan aplikasi browser.
# Jangan isi key asli di .env.example.
# PILOT_REGISTRY_FILE="config/pilot-registry.local.json"
# PILOT_API_BASE_URL="https://solar-tank-monitoring-system.vercel.app"
# PILOT_DEVICE_ID="pilot-tph-01"
# PILOT_DEVICE_KEY="isi-di-env-lokal-atau-terminal"
# PILOT_EXPECT_STORAGE="mysql"
