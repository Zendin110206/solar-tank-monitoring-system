# Cloudflare Turnstile untuk verifikasi keamanan halaman masuk.
NEXT_PUBLIC_TURNSTILE_SITE_KEY=""
TURNSTILE_SECRET_KEY=""

# Nilai di bawah hanya contoh untuk pengembangan lokal.
